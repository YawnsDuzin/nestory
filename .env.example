APP_ENV=local
APP_SECRET_KEY=change-me-with-openssl-rand-hex-32
DATABASE_URL=postgresql+psycopg://nestory:nestory@localhost:5433/nestory
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
# 관리자 기본 계정 — alembic upgrade 시점에 시드됨 (마이그레이션 f493042da765).
# - ADMIN_EMAIL 만 설정: 같은 email의 기존 user를 admin으로 승격 (없으면 no-op)
# - ADMIN_BOOTSTRAP_PASSWORD 까지 설정: argon2 hash로 신규 admin user INSERT (UPSERT)
# - 미설정: 마이그레이션이 silently skip (테스트·CI·dev 안전)
ADMIN_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=관리자
SENTRY_DSN=
NESTORY_DOMAIN=localhost:8000
SESSION_COOKIE_SECURE=false
EVIDENCE_BASE_PATH=./media-private/evidence
# Anthropic OAuth (Region Match Wizard explanations) — empty 시 fallback 정적 텍스트
ANTHROPIC_OAUTH_TOKEN=
# PostHog Cloud free analytics — empty 시 no-op
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
