APP_ENV=local
APP_SECRET_KEY=change-me-with-openssl-rand-hex-32
DATABASE_URL=postgresql+psycopg://nestory:nestory@localhost:5433/nestory
# pytest 전용 DB — DATABASE_URL과 반드시 달라야 함. autouse `_cleanup_db` fixture가
# 모든 도메인 테이블 TRUNCATE CASCADE 하므로 dev DB와 분리 필수.
# 단일 docker(5433) 인스턴스 사용 시 별도 DB명을 권장: ...:5433/nestory_test
TEST_DATABASE_URL=postgresql+psycopg://nestory:nestory@localhost:5433/nestory_test
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback
# 관리자 기본 계정 — alembic upgrade 시점에 시드됨 (마이그레이션 f493042da765).
# - APP_ENV != "production" + ADMIN_EMAIL 미설정: dev default(admin@nestory.local /
#   admin1234!)로 즉시 admin 시드. 처음 시작할 때 별도 가입 없이 admin 로그인 가능.
# - ADMIN_EMAIL 명시 + ADMIN_BOOTSTRAP_PASSWORD 명시: 해당 계정으로 INSERT(argon2 hash) /
#   같은 email의 기존 user는 role만 'admin'으로 승격 (UPSERT, password 보존).
# - ADMIN_EMAIL 명시 + ADMIN_BOOTSTRAP_PASSWORD 미설정: 같은 email 기존 user의 role만 승격.
# - APP_ENV=production + ADMIN_EMAIL 미설정: 마이그레이션 skip (보안 — prod는 ENV 강제).
ADMIN_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=관리자
SENTRY_DSN=
NESTORY_DOMAIN=localhost:8000
SESSION_COOKIE_SECURE=false
EVIDENCE_BASE_PATH=./media-private/evidence
# Anthropic OAuth (Region Match Wizard explanations) — empty 시 fallback 정적 텍스트
ANTHROPIC_OAUTH_TOKEN=
# PostHog Cloud free analytics — empty 시 no-op
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
